# Project specific ignores

# Phase I Scraper Output (you might want to commit a small sample, but not the full dataset)
phase-i-scraper/scraping_output/
# If you want to commit the structure but not the data, you could use:
# phase-i-scraper/scraping_output/*.csv
# phase-i-scraper/scraping_output/*.txt
# !phase-i-scraper/scraping_output/.gitkeep # If you add a .gitkeep file

# Phase II Assistant - Backend Screenshots (if saved locally)
phase-ii-assistant/backend/screenshots/

# Phase II Assistant - Extension (if it generates build artifacts, though unlikely for simple extensions)
# phase-ii-assistant/trademe_relab_extension/build/

# Debug files generated by your scraper/playwright
debug_*.html
debug_*.png

# Log files (if any)
*.log

# Temporary files
tmp/
temp/

# Environment files for Phase II backend (if using python-dotenv)
# The .env file itself should NOT be committed, but the example/template can be
.env
# !.env.example # Uncomment if you add an .env.example file

# Compiled executables (if any scripts generate them)
*.exe
*.out
*.app

# Node.js modules (if you use any JS tooling for the extension beyond basic files)
node_modules/

# Package manager folders
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz